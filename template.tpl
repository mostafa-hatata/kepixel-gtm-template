        } else if (kepixel && kepixel.track) {
            kepixel.track('login', { user_id: userId, traits: traits, external_ids: externalIds });
        } else {
            recordCall((kepixel) => kepixel.identify ? kepixel.identify(userId, traits, externalIds) : kepixel.track('login', { user_id: userId, traits: traits, external_ids: externalIds }));
        }
    },
    group: (groupId, traits) => {
        const kepixel = copyFromWindow(KEPIXEL_WINDOW_KEY);
