let dataLayerEventProperties = null;
let dataLayerUserId = null;
let dataLayerExternalIds = null;
let dataLayerTraits = null;
let dataLayerPageName = null;
let dataLayerGroupId = null;

if (data.tag_type == 'init') {
    let sdkCDNHost = data.cdn_host || DEFAULT_SDK_CDN_HOST;
    if(data.cookie_keeper_host && isSafari(data.user_agent)){
        sdkCDNHost = data.cookie_keeper_host;
    }

    const clientId = data.client_id || '';
    const siteId = data.site_id || 'main_site';
    const publicToken = data.public_token || data.write_key || '';
    const collectUrl = data.api_host || 'https://static.kepixel.online/v1/events';
    const sdkVersion = data.sdk_version || DEFAULT_SDK_VERSION;

    let jsScriptURL = sdkCDNHost + '/kpxtag?client_id=' + encodeUri(clientId) + '&site_id=' + encodeUri(siteId) + '&token=' + encodeUri(publicToken) + '&collect_url=' + encodeUri(collectUrl) + '&source=gtm&version=' + encodeUri(sdkVersion);
    if (data.track_page_view_on_init !== true) {
        jsScriptURL = jsScriptURL + '&manual_only=1&no_auto_page_view=1';
    }

    injectScript(jsScriptURL, init, onfailure, 'kepixel');
} else {
    switch(data.tag_type) {
        case 'identify':
            identify();
            break;

        case 'group':
            group();
            break;

        case 'track':
            track();
            break;

        case 'page':
            page();
            break;

        case 'data_layer_event':
            dataLayerEvent();
            break;

        default:
            log(LOG_PREFIX + ' Unsupported tag type `'+ data.tag_type +'`, skipping');
            break;
    }

    data.gtmOnSuccess();
}


